---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const featured = posts[0];
const rest = posts.slice(1);
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`blog — ${SITE_TITLE}`} description="Productivity science, AI deep dives, and real stories from people who use voice notes to do their best work." />
  </head>
  <body>
    <div id="cursor"></div>
    <div id="cursor-ring"></div>

    <Header />

    <!-- HERO -->
    <div class="blog-hero">
      <div class="hero-orb orb-1"></div>
      <div class="hero-orb orb-2"></div>
      <div class="hero-inner">
        <div class="section-tag">the focused. blog</div>
        <h1>Think better.<br>Capture more.</h1>
        <p>Productivity science, AI deep dives, and real stories from people who use voice notes to do their best work.</p>
      </div>
    </div>

    <!-- FILTER BAR -->
    <div class="filter-bar">
      <div class="filter-inner">
        <button class="filter-btn active" data-filter="all">all</button>
        <button class="filter-btn" data-filter="productivity">productivity</button>
        <button class="filter-btn" data-filter="ai">ai</button>
        <button class="filter-btn" data-filter="tips">tips & tricks</button>
        <button class="filter-btn" data-filter="stories">user stories</button>
        <button class="filter-btn" data-filter="engineering">engineering</button>
      </div>
    </div>

    <div class="blog-main">

      {featured && (
        <a class="featured-post reveal" href={`/blog/${featured.id}/`}>
          <div class="featured-img">
            <svg viewBox="0 0 600 400" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <rect width="600" height="400" fill="#0E1D45"/>
              <circle cx="300" cy="200" r="120" fill="none" stroke="#4B6EF5" stroke-width="0.5" stroke-dasharray="6 6" opacity="0.4"/>
              <circle cx="300" cy="200" r="75" fill="none" stroke="#6B8EFF" stroke-width="0.5" opacity="0.25"/>
              <circle cx="300" cy="200" r="30" fill="#4B6EF5" opacity="0.5"/>
              <circle cx="300" cy="200" r="12" fill="#6B8EFF" opacity="0.9"/>
              <rect x="60" y="180" width="4" height="40" rx="2" fill="#4B6EF5" opacity="0.7"/>
              <rect x="72" y="165" width="4" height="70" rx="2" fill="#6B8EFF" opacity="0.7"/>
              <rect x="84" y="175" width="4" height="50" rx="2" fill="#4B6EF5" opacity="0.7"/>
              <rect x="96" y="158" width="4" height="84" rx="2" fill="#4B6EF5" opacity="0.7"/>
              <rect x="108" y="172" width="4" height="56" rx="2" fill="#6B8EFF" opacity="0.7"/>
              <rect x="120" y="185" width="4" height="30" rx="2" fill="#4B6EF5" opacity="0.7"/>
              <rect x="468" y="178" width="4" height="44" rx="2" fill="#4B6EF5" opacity="0.7"/>
              <rect x="480" y="162" width="4" height="76" rx="2" fill="#6B8EFF" opacity="0.7"/>
              <rect x="492" y="172" width="4" height="56" rx="2" fill="#4B6EF5" opacity="0.7"/>
              <rect x="504" y="155" width="4" height="90" rx="2" fill="#4B6EF5" opacity="0.7"/>
              <rect x="516" y="170" width="4" height="60" rx="2" fill="#6B8EFF" opacity="0.7"/>
            </svg>
          </div>
          <div class="featured-body">
            <span class="post-category">blog</span>
            <h2>{featured.data.title}</h2>
            <p>{featured.data.description}</p>
            <div class="post-meta">
              <span>focused. team</span>
              <div class="meta-dot"></div>
              <span>{featured.data.pubDate.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}</span>
            </div>
            <div class="read-more">
              read article
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="#4B6EF5" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
          </div>
        </a>
      )}

      {rest.length > 0 && (
        <>
          <div class="posts-header">
            <div class="section-tag" style="margin:0">latest posts</div>
            <span class="posts-count" id="post-count">{rest.length} article{rest.length !== 1 ? 's' : ''}</span>
          </div>
          <div class="posts-grid" id="posts-grid">
            {rest.map((post) => (
              <a class="post-card reveal" href={`/blog/${post.id}/`} data-category="blog">
                <div class="post-img">
                  <svg viewBox="0 0 360 200" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <rect width="360" height="200" fill="#0E1D45"/>
                    <circle cx="180" cy="100" r="60" fill="none" stroke="#4B6EF5" stroke-width="0.8" stroke-dasharray="5 5" opacity="0.4"/>
                    <circle cx="180" cy="100" r="35" fill="rgba(75,110,245,0.15)" stroke="#6B8EFF" stroke-width="0.8"/>
                    <circle cx="180" cy="100" r="14" fill="#4B6EF5" opacity="0.7"/>
                    <rect x="40" y="88" width="4" height="24" rx="2" fill="#4B6EF5" opacity="0.6"/>
                    <rect x="50" y="78" width="4" height="44" rx="2" fill="#6B8EFF" opacity="0.6"/>
                    <rect x="60" y="84" width="4" height="32" rx="2" fill="#4B6EF5" opacity="0.6"/>
                    <rect x="290" y="86" width="4" height="28" rx="2" fill="#4B6EF5" opacity="0.6"/>
                    <rect x="300" y="76" width="4" height="48" rx="2" fill="#6B8EFF" opacity="0.6"/>
                    <rect x="310" y="82" width="4" height="36" rx="2" fill="#4B6EF5" opacity="0.6"/>
                  </svg>
                  <span class="cat-pill">blog</span>
                </div>
                <div class="post-body">
                  <h3>{post.data.title}</h3>
                  <p>{post.data.description}</p>
                  <div class="post-footer">
                    <div class="author-avatar">FT</div>
                    <span>focused. team</span>
                    <div class="meta-dot" style="background:var(--text-light)"></div>
                    <span>{post.data.pubDate.toLocaleDateString('en-US', { month: 'short', year: 'numeric' })}</span>
                  </div>
                </div>
              </a>
            ))}
          </div>
        </>
      )}

      {posts.length === 0 && (
        <p style="color:var(--text-muted);text-align:center;padding:4rem 0">No posts yet — check back soon.</p>
      )}

      <!-- NEWSLETTER -->
      <div class="newsletter reveal">
        <h3>Stay in the loop.</h3>
        <p>New articles on productivity, AI, and voice capture — delivered to your inbox twice a month.</p>
        <div class="newsletter-form">
          <input class="newsletter-input" type="email" placeholder="your@email.com" id="nl-email" />
          <button class="newsletter-btn" id="nl-btn">subscribe</button>
        </div>
      </div>

    </div>

    <Footer />
  </body>
</html>

<style>
  /* CURSOR */
  #cursor { position: fixed; width: 20px; height: 20px; border-radius: 50%; background: var(--accent); pointer-events: none; z-index: 9999; mix-blend-mode: multiply; transition: transform 0.15s, opacity 0.3s; transform: translate(-50%, -50%); }
  #cursor-ring { position: fixed; width: 40px; height: 40px; border-radius: 50%; border: 1.5px solid var(--accent); pointer-events: none; z-index: 9998; transform: translate(-50%, -50%); transition: all 0.1s; opacity: 0.5; }

  /* HERO */
  .blog-hero {
    padding: 10rem 3rem 5rem;
    background: var(--navy);
    position: relative; overflow: hidden;
  }
  .hero-orb { position: absolute; border-radius: 50%; filter: blur(80px); pointer-events: none; }
  .orb-1 { width: 500px; height: 500px; background: #2040C0; opacity: 0.25; top: -150px; left: -100px; }
  .orb-2 { width: 300px; height: 300px; background: #4B6EF5; opacity: 0.15; bottom: -80px; right: 10%; }
  .hero-inner { max-width: 1200px; margin: 0 auto; position: relative; z-index: 1; }
  .section-tag { display: inline-block; font-size: 0.75rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--accent); margin-bottom: 1rem; }
  .blog-hero h1 { font-family: 'Space Grotesk', sans-serif; font-size: clamp(2.5rem, 5vw, 4rem); font-weight: 700; letter-spacing: -0.04em; line-height: 1.05; color: var(--white); margin-bottom: 1.25rem; }
  .blog-hero p { font-size: 1.125rem; color: rgba(255,255,255,0.5); max-width: 480px; line-height: 1.7; margin: 0; }

  /* FILTER BAR */
  .filter-bar { background: var(--white); border-bottom: 1px solid var(--border); position: sticky; top: 73px; z-index: 50; }
  .filter-inner { max-width: 1200px; margin: 0 auto; padding: 0 3rem; display: flex; gap: 0.5rem; overflow-x: auto; scrollbar-width: none; }
  .filter-inner::-webkit-scrollbar { display: none; }
  .filter-btn { font-family: 'Inter', sans-serif; font-size: 0.85rem; font-weight: 500; padding: 1rem 1.25rem; border: none; background: transparent; color: var(--text-muted); cursor: pointer; white-space: nowrap; border-bottom: 2px solid transparent; transition: all 0.2s; }
  .filter-btn:hover { color: var(--navy); }
  .filter-btn.active { color: var(--accent); border-bottom-color: var(--accent); }

  /* MAIN */
  .blog-main { max-width: 1200px; margin: 0 auto; padding: 4rem 3rem 7rem; }

  /* FEATURED */
  .featured-post {
    display: grid; grid-template-columns: 1fr 1fr; gap: 0;
    border-radius: var(--radius); overflow: hidden;
    border: 1px solid var(--border); margin-bottom: 4rem;
    text-decoration: none; color: inherit; transition: all 0.3s;
  }
  .featured-post:hover { box-shadow: 0 24px 64px rgba(7,16,42,0.12); transform: translateY(-3px); }
  .featured-img {
    background: var(--navy-mid); min-height: 400px;
    position: relative; overflow: hidden;
    display: flex; align-items: center; justify-content: center;
  }
  .featured-img svg { width: 100%; height: 100%; position: absolute; inset: 0; }
  .featured-body { padding: 3rem; display: flex; flex-direction: column; justify-content: center; }
  .post-category { display: inline-block; font-size: 0.75rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: var(--accent); margin-bottom: 1rem; }
  .featured-body h2 { font-family: 'Space Grotesk', sans-serif; font-size: 1.875rem; font-weight: 700; letter-spacing: -0.03em; line-height: 1.15; margin-bottom: 1rem; color: var(--navy); }
  .featured-body p { font-size: 1rem; color: var(--text-muted); line-height: 1.7; margin-bottom: 2rem; }
  .post-meta { display: flex; align-items: center; gap: 0.75rem; font-size: 0.8rem; color: var(--text-light); }
  .meta-dot { width: 3px; height: 3px; background: var(--text-light); border-radius: 50%; }
  .read-more { display: inline-flex; align-items: center; gap: 0.5rem; font-size: 0.875rem; font-weight: 600; color: var(--accent); margin-top: 1.5rem; }
  .read-more svg { transition: transform 0.2s; }
  .featured-post:hover .read-more svg { transform: translateX(4px); }

  /* GRID */
  .posts-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem; }
  .posts-count { font-size: 0.85rem; color: var(--text-light); }
  .posts-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }
  .post-card {
    border-radius: var(--radius); overflow: hidden; border: 1px solid var(--border);
    text-decoration: none; color: inherit;
    display: flex; flex-direction: column; transition: all 0.3s; background: var(--white);
  }
  .post-card:hover { transform: translateY(-5px); box-shadow: 0 20px 50px rgba(7,16,42,0.1); border-color: transparent; }
  .post-img { height: 200px; background: var(--navy-mid); position: relative; overflow: hidden; flex-shrink: 0; }
  .post-img svg { position: absolute; inset: 0; width: 100%; height: 100%; }
  .cat-pill { position: absolute; bottom: 12px; left: 12px; background: rgba(75,110,245,0.85); backdrop-filter: blur(8px); font-size: 0.7rem; font-weight: 600; letter-spacing: 0.06em; text-transform: uppercase; padding: 4px 10px; border-radius: var(--radius-pill); color: white; }
  .post-body { padding: 1.5rem; flex: 1; display: flex; flex-direction: column; }
  .post-body h3 { font-family: 'Space Grotesk', sans-serif; font-size: 1.0625rem; font-weight: 600; letter-spacing: -0.02em; line-height: 1.3; margin-bottom: 0.625rem; color: var(--navy); }
  .post-body p { font-size: 0.875rem; color: var(--text-muted); line-height: 1.65; flex: 1; margin-bottom: 1.25rem; }
  .post-footer { display: flex; align-items: center; gap: 0.625rem; font-size: 0.8rem; color: var(--text-light); margin-top: auto; padding-top: 1rem; border-top: 1px solid var(--border); }
  .author-avatar { width: 24px; height: 24px; border-radius: 50%; background: linear-gradient(135deg, var(--accent), var(--accent-glow)); display: flex; align-items: center; justify-content: center; font-size: 0.6rem; font-weight: 700; color: white; flex-shrink: 0; }

  /* NEWSLETTER */
  .newsletter { background: var(--surface); border-radius: var(--radius); padding: 3rem; text-align: center; border: 1px solid var(--border); margin-top: 4rem; }
  .newsletter h3 { font-family: 'Space Grotesk', sans-serif; font-size: 1.5rem; font-weight: 700; letter-spacing: -0.03em; color: var(--navy); margin-bottom: 0.625rem; }
  .newsletter p { font-size: 0.9375rem; color: var(--text-muted); margin-bottom: 1.75rem; }
  .newsletter-form { display: flex; gap: 0.75rem; max-width: 440px; margin: 0 auto; }
  .newsletter-input { flex: 1; padding: 0.8rem 1rem; border: 1.5px solid var(--border); border-radius: var(--radius-pill); font-family: 'Inter', sans-serif; font-size: 0.9rem; color: var(--navy); background: var(--white); transition: border-color 0.2s; }
  .newsletter-input:focus { outline: none; border-color: var(--accent); }
  .newsletter-input::placeholder { color: var(--text-light); }
  .newsletter-btn { padding: 0.8rem 1.5rem; background: var(--navy); color: white; border: none; border-radius: var(--radius-pill); font-family: 'Inter', sans-serif; font-size: 0.875rem; font-weight: 500; cursor: pointer; white-space: nowrap; transition: all 0.2s; }
  .newsletter-btn:hover { background: var(--accent); transform: translateY(-1px); }

  /* REVEAL */
  .reveal { opacity: 0; transform: translateY(24px); transition: opacity 0.6s ease, transform 0.6s ease; }
  .reveal.visible { opacity: 1; transform: none; }

  @media (max-width: 900px) {
    .blog-hero, .blog-main { padding-left: 1.5rem; padding-right: 1.5rem; }
    .filter-inner { padding: 0 1.5rem; }
    .featured-post { grid-template-columns: 1fr; }
    .featured-img { min-height: 240px; }
    .posts-grid { grid-template-columns: 1fr; }
    .newsletter-form { flex-direction: column; }
  }
</style>

<script>
  // Cursor
  const cur = document.getElementById('cursor');
  const curRing = document.getElementById('cursor-ring');
  let mx=0, my=0, rx=0, ry=0;
  document.addEventListener('mousemove', e => { mx=e.clientX; my=e.clientY; });
  function animCursor() {
    rx += (mx-rx)*0.15; ry += (my-ry)*0.15;
    if (cur) { cur.style.left=mx+'px'; cur.style.top=my+'px'; }
    if (curRing) { curRing.style.left=rx+'px'; curRing.style.top=ry+'px'; }
    requestAnimationFrame(animCursor);
  }
  animCursor();
  document.querySelectorAll('a,button,.post-card').forEach(el => {
    el.addEventListener('mouseenter', () => { if(cur){cur.style.transform='translate(-50%,-50%) scale(2.5)';cur.style.opacity='0.4';} });
    el.addEventListener('mouseleave', () => { if(cur){cur.style.transform='translate(-50%,-50%) scale(1)';cur.style.opacity='1';} });
  });

  // Reveal
  const obs = new IntersectionObserver(entries => {
    entries.forEach((e, i) => { if(e.isIntersecting) setTimeout(() => e.target.classList.add('visible'), i*80); });
  }, {threshold: 0.08});
  document.querySelectorAll('.reveal').forEach(r => obs.observe(r));

  // Filter
  const filterBtns = document.querySelectorAll('.filter-btn');
  const cards = document.querySelectorAll('.post-card');
  const countEl = document.getElementById('post-count');
  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      filterBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      const f = (btn as HTMLElement).dataset.filter;
      let visible = 0;
      cards.forEach(c => {
        const match = f==='all' || (c as HTMLElement).dataset.category===f;
        (c as HTMLElement).style.display = match ? 'flex' : 'none';
        if(match) visible++;
      });
      if(countEl) countEl.textContent = visible + ' article' + (visible!==1?'s':'');
    });
  });

  // Newsletter
  document.getElementById('nl-btn')?.addEventListener('click', () => {
    const btn = document.getElementById('nl-btn') as HTMLButtonElement;
    const input = document.getElementById('nl-email') as HTMLInputElement;
    if(!input?.value) return;
    btn.textContent = 'subscribed ✓';
    btn.style.background = '#22C55E';
    input.value = '';
    setTimeout(() => { btn.textContent='subscribe'; btn.style.background=''; }, 3000);
  });
</script>
